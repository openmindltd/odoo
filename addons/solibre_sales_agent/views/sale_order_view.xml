<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_solibre_sales_agent" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.solibre.sales.agent</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other_information']//field[@name='team_id']" position="after">
                <field name="sales_agent_id"/>
            </xpath>
        </field>
    </record>
</odoo>
